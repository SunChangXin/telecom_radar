# ===== 基础 =====
RADAR_CONFIG=./config/config.example.json
RADAR_DB=./data/radar.sqlite3
RADAR_REPORT_DIR=./data/reports
RADAR_TIMEZONE=Asia/Shanghai

# 每次最多推送多少条。太多会刷屏。
MAX_ITEMS_PER_RUN=12
MIN_SCORE_TO_NOTIFY=2

# ===== LLM 总结，可选。不填也能跑，会用规则模板生成摘要。 =====
# OpenAI Responses API：如果填了 OPENAI_API_KEY，会自动调用模型生成中文摘要。
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_BASE_URL=https://api.openai.com/v1

# ===== GitHub，可选。不填也能抓公开搜索，但容易遇到较低频率限制。 =====
GITHUB_TOKEN=

# ===== 手机推送，至少配置一种 =====
# 方案A：ntfy。安卓推荐，安装 ntfy App，订阅一个足够随机的 topic。
NTFY_SERVER=https://ntfy.sh
NTFY_TOPIC=

# 方案B：Server酱 / ServerChan。适合微信推送。
# Server酱3：形如 https://<uid>.push.ft07.com/send/<sendkey>.send
# 旧版Turbo：可只填 SCT_SENDKEY，代码会请求 https://sctapi.ftqq.com/<SCT_SENDKEY>.send
SERVERCHAN_URL=
SCT_SENDKEY=

# 方案C：任意 Webhook，POST JSON: {title, text, items}
WEBHOOK_URL=

# ===== Vercel + Supabase 云端部署 =====
# Supabase Project Settings -> API
SUPABASE_URL=
# 只放在 Vercel Environment Variables，不要暴露到浏览器。
SUPABASE_SERVICE_ROLE_KEY=

# 可选：只在你不用 Vercel Cron、改用外部调度器时启用。
# 启用后请求 /api/radar 需要带 Authorization: Bearer <CRON_SECRET>
CRON_SECRET=
